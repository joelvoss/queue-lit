{
  "name": "queue-lit",
  "description": "queue-lit is a tiny queue data structure in case you `Array#push()` or `Array#shift()` on large arrays very often",
  "version": "3.1.0",
  "author": "Joel Voss <mail@joelvoss.com>",
  "license": "MIT",
  "homepage": "https://github.com/joelvoss/queue-lit",
  "bugs": {
    "url": "https://github.com/joelvoss/queue-lit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelvoss/queue-lit.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "./Taskfile.sh test",
    "build": "./Taskfile.sh build"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typescript": "6.0.2",
    "vite": "8.0.5",
    "vite-plugin-bundle-dts": "0.2.0",
    "vitest": "4.1.1"
  }
}
